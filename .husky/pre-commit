#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔒 Running pre-commit security checks..."

# Run security linting (allow warnings)
echo "📝 Checking code quality and security..."
npm run lint:security -- --max-warnings 50 || echo "⚠️ Security linting has warnings but continuing..."

# Check formatting
echo "🎨 Checking code formatting..."
npm run format:check || echo "⚠️ Formatting issues found but continuing..."

# Type checking
echo "🔍 Running TypeScript checks..."
npm run type-check || echo "⚠️ Type checking issues found but continuing..."

# Run security tests (allow failures for now)
echo "🧪 Running security tests..."
npm run test:security || echo "⚠️ Security tests have issues but continuing..."

echo "✅ Pre-commit checks completed (with warnings allowed)!"