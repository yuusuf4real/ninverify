# Database
DATABASE_URL="postgres://user:password@host/db"

# Session Management
JWT_SECRET="replace-with-strong-secret-minimum-32-characters"

# Paystack (Production)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_your_public_key_here"
PAYSTACK_SECRET_KEY="sk_live_your_secret_key_here"

# OTP Service Configuration
# Primary: Termii (Nigerian SMS provider)
TERMII_API_KEY="your_production_termii_api_key"
# N-Alert is a pre-approved generic sender ID that works immediately
# To use custom sender ID like "VerifyNIN", register it at https://accounts.termii.com
TERMII_SENDER_ID="NINverify"

# Backup: Twilio (International SMS provider)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+1234567890"

# OTP Provider Selection (termii or twilio)
OTP_PROVIDER="termii"

# YouVerify Configuration
# IMPORTANT: Environment-based configuration for YouVerify API
# 
# For LOCAL DEVELOPMENT (use staging):
# YOUVERIFY_ENVIRONMENT="staging"
# YOUVERIFY_TOKEN="your_staging_token_here"
# YOUVERIFY_BASE_URL="https://api.sandbox.youverify.co"
#
# For PRODUCTION DEPLOYMENT (use production):
# YOUVERIFY_ENVIRONMENT="production" 
# YOUVERIFY_TOKEN="your_production_token_here"
# YOUVERIFY_BASE_URL="https://api.youverify.co"
#
# Setup Instructions:
# 1. Create API key at os.youverify.co → Account Settings → API/Webhooks
# 2. Enable NIN permission when creating the key
# 3. For staging: Use TEST environment key with sandbox URL
# 4. For production: Use LIVE environment key with production URL
# 5. Ensure business account is fully onboarded (KYB complete)
#
# Common Errors:
# - 401: Wrong environment (staging token with production URL or vice versa)
# - 402: Insufficient wallet balance → Top up wallet (production only)
# - 403: Missing NIN permission → Regenerate key with NIN enabled
#
YOUVERIFY_ENVIRONMENT="production"
YOUVERIFY_TOKEN="your_production_youverify_token"
YOUVERIFY_BASE_URL="https://api.youverify.co"

# Security & Compliance
# Generate strong random string: openssl rand -base64 32
ENCRYPTION_KEY="your-encryption-key-for-sensitive-data"

# Admin System
# First super admin credentials (used by scripts/create-super-admin.ts)
FIRST_SUPER_ADMIN_EMAIL="admin@verifynin.ng"
FIRST_SUPER_ADMIN_PASSWORD="ChangeMe123!"

# Admin Security Configuration
ADMIN_IP_WHITELIST="127.0.0.1,::1,::ffff:127.0.0.1,localhost,192.168.1.0/24"  # Comma-separated IPs/CIDR blocks for admin access

# Session-Based System Configuration
SESSION_DURATION_MINUTES="30"  # How long verification sessions last
OTP_EXPIRY_MINUTES="10"        # How long OTP codes are valid
MAX_OTP_ATTEMPTS="3"           # Maximum OTP verification attempts

# Rate Limiting & Fraud Prevention
MAX_DAILY_VERIFICATIONS_PER_PHONE="5"  # Per phone number
MAX_HOURLY_OTP_REQUESTS="10"           # Per phone number
MIN_PAYMENT_AMOUNT="50000"             # ₦500 in kobo (demographic)
MAX_PAYMENT_AMOUNT="100000"            # ₦1000 in kobo (full profile)

# Monitoring & Logging (Optional but recommended)
SENTRY_DSN="your-sentry-dsn-for-error-tracking"
LOG_LEVEL="info"  # debug, info, warn, error

# Webhook Security (Optional - for IP whitelisting)
# ALLOWED_WEBHOOK_IPS="52.31.139.75,52.49.173.169,52.214.14.220"

# Data Retention (NDPR Compliance)
DATA_RETENTION_DAYS="365"  # How long to keep session data

# Feature Flags
ENABLE_RATE_LIMITING="true"
ENABLE_AUDIT_LOGGING="true"
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION="true"
ENABLE_SESSION_CLEANUP="true"  # Auto-cleanup expired sessions
