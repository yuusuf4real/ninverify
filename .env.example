# Database
DATABASE_URL="postgres://user:password@host/db"

# Session Management
JWT_SECRET="replace-with-strong-secret-minimum-32-characters"

# Paystack (Production)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_your_public_key_here"
PAYSTACK_SECRET_KEY="sk_live_your_secret_key_here"

# OTP Service Configuration - Multi-Provider Setup for Maximum Reliability
# Providers are tried in priority order until one succeeds

# Provider Priority (comma-separated, highest priority first)
# Available: textbelt, bulksms, twilio, termii
# Default: textbelt (free), bulksms (50 free SMS), twilio (reliable), termii (backup)
OTP_PROVIDER_PRIORITY="textbelt,bulksms,twilio,termii"

# TextBelt (Completely Free - 1 SMS per day per IP)
# No signup required! Use "textbelt" for free tier or get paid key for unlimited
# Free tier: 1 SMS/day per IP address (perfect for testing)
# Paid: $0.15 per SMS (very affordable)
# Coverage: US, Canada, International
TEXTBELT_API_KEY="textbelt"  # Use "textbelt" for free tier

# BulkSMS Nigeria (50 Free SMS + ₦6 per SMS)
# Sign up at: https://www.bulksmsnigeria.com
# Get 50 free SMS credits on signup - perfect for initial users
# Production: Only ₦6 per SMS (most cost-effective for Nigeria)
# Coverage: Nigeria-focused with excellent local delivery rates
BULKSMS_NIGERIA_API_TOKEN="your_bulksms_api_token_here"
BULKSMS_NIGERIA_SENDER_ID="VerifyNIN"

# Termii (Nigerian SMS provider) - PRODUCTION READY CONFIGURATION
# CRITICAL: Use DND route for OTP messages to bypass DND restrictions
TERMII_API_KEY="your_production_termii_api_key_here"
TERMII_SENDER_ID="N-Alert"  # Pre-approved sender ID for DND route
TERMII_BASE_URL="https://api.ng.termii.com"  # Official Termii API endpoint

# IMPORTANT SETUP STEPS FOR TERMII PRODUCTION:
# 1. Contact support@termii.com to activate DND route on your account
# 2. Use "N-Alert" sender ID (pre-approved) or request custom sender ID whitelisting
# 3. Ensure sufficient account balance for SMS delivery
# 4. Test with DND-enabled numbers to confirm delivery
#
# Support Contacts:
# - Email: support@termii.com
# - Phone: +234 803 644 2972 (Nigeria)
# - Phone: +225 057 447 9488 (International)
#
# DND Route Benefits:
# ✅ Delivers to ALL Nigerian numbers (including DND-enabled)
# ✅ No time restrictions (24/7 delivery)
# ✅ Bypasses promotional message filtering
# ✅ Prioritized delivery by telecom operators
# ✅ 95-99% delivery success rate (vs 40-60% with generic route)

# Alternative: Twilio (International SMS provider - works globally)
# Get these from https://console.twilio.com
# 1. Account SID: Found on your Twilio Console Dashboard
# 2. Auth Token: Found on your Twilio Console Dashboard (click "show" to reveal)
# 3. Phone Number: Purchase a phone number from Twilio Console > Phone Numbers > Manage > Buy a number
#    - For Nigeria: Buy a Nigerian number (+234) for better delivery rates
#    - For International: Any Twilio number works but may have higher costs
# 4. Trial Account Limitations: Can only send to verified numbers
# 5. Production Account: Can send to any valid phone number
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+1234567890"

# YouVerify Configuration
# IMPORTANT: Environment-based configuration for YouVerify API
# 
# For LOCAL DEVELOPMENT (use staging):
# YOUVERIFY_ENVIRONMENT="staging"
# YOUVERIFY_TOKEN="your_staging_token_here"
# YOUVERIFY_BASE_URL="https://api.sandbox.youverify.co"
#
# For PRODUCTION DEPLOYMENT (use production):
# YOUVERIFY_ENVIRONMENT="production" 
# YOUVERIFY_TOKEN="your_production_token_here"
# YOUVERIFY_BASE_URL="https://api.youverify.co"
#
# Setup Instructions:
# 1. Create API key at os.youverify.co → Account Settings → API/Webhooks
# 2. Enable NIN permission when creating the key
# 3. For staging: Use TEST environment key with sandbox URL
# 4. For production: Use LIVE environment key with production URL
# 5. Ensure business account is fully onboarded (KYB complete)
#
# Common Errors:
# - 401: Wrong environment (staging token with production URL or vice versa)
# - 402: Insufficient wallet balance → Top up wallet (production only)
# - 403: Missing NIN permission → Regenerate key with NIN enabled
#
YOUVERIFY_ENVIRONMENT="production"
YOUVERIFY_TOKEN="your_production_youverify_token"
YOUVERIFY_BASE_URL="https://api.youverify.co"

# Security & Compliance
# Generate strong random string: openssl rand -base64 32
ENCRYPTION_KEY="your-encryption-key-for-sensitive-data"

# Admin System
# First super admin credentials (used by scripts/create-super-admin.ts)
FIRST_SUPER_ADMIN_EMAIL="admin@verifynin.ng"
FIRST_SUPER_ADMIN_PASSWORD="ChangeMe123!"

# Admin Security Configuration
ADMIN_IP_WHITELIST="127.0.0.1,::1,::ffff:127.0.0.1,localhost,192.168.1.0/24"  # Comma-separated IPs/CIDR blocks for admin access

# Session-Based System Configuration
SESSION_DURATION_MINUTES="30"  # How long verification sessions last
OTP_EXPIRY_MINUTES="10"        # How long OTP codes are valid
MAX_OTP_ATTEMPTS="3"           # Maximum OTP verification attempts

# Rate Limiting & Fraud Prevention
MAX_DAILY_VERIFICATIONS_PER_PHONE="5"  # Per phone number
MAX_HOURLY_OTP_REQUESTS="10"           # Per phone number
MIN_PAYMENT_AMOUNT="50000"             # ₦500 in kobo (demographic)
MAX_PAYMENT_AMOUNT="100000"            # ₦1000 in kobo (full profile)

# Monitoring & Logging (Optional but recommended)
SENTRY_DSN="your-sentry-dsn-for-error-tracking"
LOG_LEVEL="info"  # debug, info, warn, error

# Webhook Security (Optional - for IP whitelisting)
# ALLOWED_WEBHOOK_IPS="52.31.139.75,52.49.173.169,52.214.14.220"

# Data Retention (NDPR Compliance)
DATA_RETENTION_DAYS="365"  # How long to keep session data

# Feature Flags
ENABLE_RATE_LIMITING="true"
ENABLE_AUDIT_LOGGING="true"
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION="true"
ENABLE_SESSION_CLEANUP="true"  # Auto-cleanup expired sessions
