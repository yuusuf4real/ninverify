{
  "name": "verifynin",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "WS_NO_BUFFER_UTIL=1 next dev",
    "build": "next build",
    "start": "WS_NO_BUFFER_UTIL=1 next start",
    "lint": "next lint",
    "lint:security": "eslint . --config .eslintrc.security.json --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write . --config .prettierrc.security",
    "format:check": "prettier --check . --config .prettierrc.security",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:security": "jest tests/security --verbose",
    "test:integration:security": "jest tests/integration/security --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:accessibility": "pa11y http://localhost:3000",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "admin:create": "tsx scripts/create-super-admin.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:scan": "npm run lint:security && npm run test:security",
    "pre-commit": "npm run lint:security && npm run format:check && npm run type-check && npm run test:security",
    "prepare": "husky install",
    "ci:full": "npm run lint && npm run lint:security && npm run format:check && npm run type-check && npm run test && npm run test:security && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@neondatabase/serverless": "^0.10.4",
    "@paystack/inline-js": "^2.22.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "framer-motion": "^11.18.2",
    "isomorphic-dompurify": "^2.9.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.473.0",
    "nanoid": "^5.0.7",
    "next": "^15.4.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.6.0",
    "server-only": "^0.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.14.12",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.4.10",
    "eslint-plugin-no-secrets": "^0.8.9",
    "eslint-plugin-security": "^2.1.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.49",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "@playwright/test": "^1.40.0",
    "pa11y": "^8.0.0",
    "depcheck": "^1.4.7"
  }
}
